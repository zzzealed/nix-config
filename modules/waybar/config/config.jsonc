{
  "layer": "top",
  "position": "bottom",
  "spacing": 15,
  "margin-top": 0,
  "margin-right": 0,
  "margin-left": 0,
  "margin-bottom": 0,
  "modules-left": [
    "niri/window"
  ],
  "modules-center": [],
  "modules-right": [
    "custom/wg-quick",
    "memory",
    "clock"
  ],
  // Modules
  "niri/window": {
    "format": "{}",
    "icon": true,
    "icon-size": 15
  },
  "memory": {
    "format": "{percentage}% RAM"
  },
  "clock": {
    "interval": 1,
    "format": "{:%T %D}"
  },
  "custom/wg-quick": {
    "exec": "~/.config/waybar/wg-quick.sh",
    "format": "{}",
    "interval": 1
  }
}